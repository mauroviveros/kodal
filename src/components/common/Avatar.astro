---
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'figure'> {}
const { class: className, ...props } = Astro.props;
const { pet, avatar_url } =  Astro.locals;
---

<figure
  class:list={[
    "relative size-32 overflow-hidden rounded-full ring-primary/20 bg-primary/20 ring-4 ",
    className
  ]}
  {...props}
>
  {avatar_url ? (
    <img
      src={avatar_url}
      alt={`Foto de ${pet?.name ?? 'tu mascota'}`}
      class="aspect-square size-full object-cover"
    />
  ) : (
    <span class="flex size-full items-center justify-center text-6xl font-bold select-none bg-primary/80 text-primary-foreground">
      {(pet?.name || '�').charAt(0)}
    </span>
  )}
</figure>
