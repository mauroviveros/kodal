---
import { Icon } from "astro-icon/components";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/starwind/card";
import type { Tables } from "@/interfaces";
import { OWNER_RELATION_LABELS } from "@/constants";
import { email_mask } from "@/utils";

type Props = Pick<Tables<'owners'>, 'full_name' | 'phone' | 'email' | 'relation_type' | 'address'>;
const { phone, email, full_name, relation_type, address } = Astro.props;

type Field = {
  label: string;
  icon: string;
  display: string | null;
  action?: { href: string };
};

const addressUrl = address
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`
  : null;

const FIELDS: Field[] = [
  { label: 'Teléfono', icon: 'lucide:phone', display: phone },
  { label: 'Correo electrónico', icon: 'lucide:mail', display: email_mask(email) },
  { label: 'Dirección', icon: 'lucide:map-pin', display: address, action: addressUrl ? { href: addressUrl } : undefined },
];
---
<Card class="animate-fade-in-up">
  <CardHeader class="flex items-center gap-2">
    <Icon name="lucide:contact" class="size-6 text-primary" />
    <hgroup class="truncate">
      <CardTitle class="truncate">Información de contacto</CardTitle>
      <CardDescription class="truncate">Mi <span class="lowercase">{OWNER_RELATION_LABELS[relation_type].label}</span> es <strong>{full_name}</strong></CardDescription>
    </hgroup>
  </CardHeader>

  <CardContent class="space-y-3">
    {
      FIELDS
        .filter(({ display }) => display)
        .map(({ icon, label, display, action }) => {
          if (action) {
            return (
              <a
                href={action.href}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-muted/30 grid grid-cols-[auto_1fr_auto] items-center gap-x-2 rounded-lg p-4 hover:bg-muted/50 transition-colors group"
              >
                <span class="bg-primary/10 row-span-2 flex size-10 items-center justify-center rounded-full">
                  <Icon name={icon} class="text-primary size-5" />
                </span>
                <dt class="font-medium truncate">{label}</dt>
                <dd class="text-primary truncate col-start-2 text-sm">{display}</dd>
                <span class="row-span-2 col-start-3 row-start-1 flex size-10 items-center justify-center rounded-full group-hover:bg-primary/20 transition-colors">
                  <Icon name="lucide:external-link" class="size-5 text-muted-foreground group-hover:text-primary transition-colors" />
                </span>
              </a>
            );
          }

          return (
            <dl class="bg-muted/30 grid grid-cols-[auto_1fr] grid-rows-2 items-center gap-x-2 rounded-lg p-4">
              <span class="bg-primary/10 row-span-2 flex size-10 items-center justify-center rounded-full">
                <Icon name={icon} class="text-primary size-5" />
              </span>
              <dt class="font-medium truncate">{label}</dt>
              <dd class="text-primary truncate">{display}</dd>
            </dl>
          );
        })
    }
  </CardContent>
</Card>
