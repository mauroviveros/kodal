---
import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";
import { PURCHASE_LINK } from "@/constants";
---

<Card class="text-center animate-fade-in-up">
  <CardContent class="p-6">
    <h3 class="text-xl font-bold text-foreground mb-3">Te gusta esta medalla inteligente?</h3>
    <p class="text-muted-foreground mb-6 text-pretty">Protege a tu mascota con nuestra tecnologia de identificacion digital. Facil de usar, siempre actualizada y disponible 24/7.</p>

    <Button size="lg" class="w-full md:w-auto" variant="primary" href={PURCHASE_LINK} target="_blank" rel="noopener noreferrer">
      Consigue tu Medalla Inteligente
    </Button>
  </CardContent>
</Card>
