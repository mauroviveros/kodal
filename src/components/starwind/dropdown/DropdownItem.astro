---
import type { HTMLTag, Polymorphic } from "astro/types";

import { dropdownItem } from "./variants";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
  /**
   * Whether the item is inset (has left padding)
   */
  inset?: boolean;
  /**
   * Whether the item is disabled
   */
  disabled?: boolean;
  /**
   * The variant of the item
   */
  variant?: "default" | "destructive";
};

const { class: className, inset = false, disabled = false, variant = "default", as: Tag = "div", ...rest } = Astro.props;
---

<Tag
  class={dropdownItem({ variant, inset, disabled, class: className })}
  role="menuitem"
  tabindex={disabled ? "-1" : "0"}
  data-disabled={disabled ? "true" : undefined}
  data-slot="dropdown-item"
  {...rest}
>
  <slot />
</Tag>
