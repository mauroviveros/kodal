---
import MedalsTable from "@/components/dashboard/medals";
import Dashboard from "@/layouts/Dashboard.astro";
import { root } from "@/supabase/server";

const { data, error } = await root.from('medals').select('*');
if(error) return null;
---

<Dashboard title="Medallas" subtitle="Gestiona todas tus medallas inteligentes">
  <MedalsTable
    data={data}
    client:load
  />
</Dashboard>
