---
import Mockup from "@/components/Mockup.astro";
import Badge from "@/components/starwind/badge";
import Button from "@/components/starwind/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/starwind/card";
import { FEATURES, PURCHASE_LINK } from "@/constants";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
export const prerender = true;
---
<Layout>
  <section class="from-secondary/5 to-primary/15 bg-linear-to-br min-h-dvh md:max-h-300 pt-20 pb-4 flex items-center">
    <div class="container mx-auto max-w-5xl h-full p-4 flex flex-col md:flex-row items-center justify-between gap-y-8">
      <div class="flex-2 flex flex-col items-center justify-center text-center md:text-left md:items-start animate-zoom-in">
        <Badge variant="secondary" class="mb-2">
          <Icon name="lucide:shield-user" class="size-5"/>
          Porque perderlos no deberia ser una opción
        </Badge>

        <h1 class="text-4xl lg:text-6xl font-bold text-foreground mb-6 text-balance">
          Mantén a tu mascota <span class="text-primary">segura y conectada</span> siempre
        </h1>

        <p class="text-xl text-muted-foreground mb-8 text-pretty max-w-xl">
          Solo escanee el codigo QR en la parte posterior de la medalla para acceder a la información.
        </p>

        <article class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button size="lg" variant="primary" href={PURCHASE_LINK} target="_blank" rel="noopener noreferrer">
            Consigue tu Medalla
            <Icon name="lucide:shopping-cart" />
          </Button>
        </article>
      </div>

      <div class="flex-1 flex items-center justify-center animate-zoom-in animate-delay-100">
        <Mockup
          medal_id="ef1f70fb-c2b5-4c91-b21b-8837c06cadd3"
          class="shrink-0"
        />
      </div>
    </div>
  </section>

  <section class="py-20 bg-muted/30">
    <div class="container mx-auto px-4">
      <hgroup class="text-center mb-16 timeline-view animate-blurred-fade-in animate-duration-slower animate-range-[entry_5%_contain_20%]">
        <h2 class="text-3xl lg:text-4xl font-bold text-foreground mb-4">¿Por qué elegir Kodal?</h2>
        <p class="text-xl text-muted-foreground max-w-2xl mx-auto">Tecnología avanzada diseñada específicamente para la seguridad de tu mascota</p>
      </hgroup>
      <article class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {FEATURES.map(({title, description, icon }) => (
          <Card class="text-center timeline-view animate-zoom-in animate-duration-slower animate-range-[entry_5%_contain_20%]">
            <CardHeader>
              <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                <Icon name={icon} class="size-6 text-primary" />
              </div>
              <CardTitle>{title}</CardTitle>
            </CardHeader>
            <CardContent>
              <p class="text-muted-foreground">{description}</p>
            </CardContent>
          </Card>
        ))}
      </article>
      </div>
  </section>

  <section class="py-20 bg-primary text-primary-foreground">
    <div class="container mx-auto px-4 text-center">
      <hgroup class="mb-8 space-y-4 timeline-view animate-blurred-fade-in animate-duration-slower animate-range-[entry_5%_contain_20%]">
        <h2 class="text-3xl lg:text-4xl font-bold">¿Listo para proteger a tu mascota?</h2>
        <p class="text-xl opacity-90 max-w-2xl mx-auto">
          Únete a esta comunidad de dueños que ya confían en Kodal para mantener a sus mascotas seguras.
        </p>
      </hgroup>

      <article class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button class="animate-bounce" size="lg" variant="outline" href={PURCHASE_LINK} target="_blank" rel="noopener noreferrer">
          Consigue tu Medalla Ahora
          <Icon name="lucide:arrow-right" />
        </Button>
      </article>
    </div>
  </section>
</Layout>
