---
import { actions, isInputError } from "astro:actions";
import Layout from "@layout";
import { Form } from "@components";

const result = Astro.getActionResult(actions.insertPetForm);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
if (result?.data?.medal?.id) return Astro.redirect(`/medal/${result.data.medal.id}`);
if (result?.error) {
  console.error(result.error);
  if (!Object.keys(inputErrors).length) {
    alert(result.error.message);
  }
}

const { medal, pet, owner } = Astro.locals;
if (pet) return Astro.redirect(`/medal/${medal.id}`);
---

<Layout class="max-w-2xl" title="Kodal - Nueva medalla">
  <hgroup class="mb-6 flex flex-col gap-2">
    <h1 class="text-3xl font-bold">Crear información de tu mascota</h1>
    <p class="text-muted-foreground">Completa los datos de tu mascota para crear su perfil.</p>
  </hgroup>

  <Form
    method="POST"
    client:only="react"
    medal_id={medal.id}
    owner={owner}
  />
</Layout>
