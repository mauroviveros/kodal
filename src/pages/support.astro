---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/starwind/card";
import { SUPPORT_CONTACT_METHODS, SUPPORT_FREQUENTLY_ASKED_QUESTIONS } from "@/constants";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
export const prerender = true;
---
<Layout container>
  <header class="mb-8 text-center">
    <Icon name="lucide:headset" class="size-16 text-primary mx-auto mb-4"/>
    <h1 class="text-3xl font-bold text-foreground mb-2">Centro de Soporte</h1>
    <p class="text-muted-foreground">Estamos aquí para ayudarte con tu medalla inteligente Kodal</p>
  </header>

  <section class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <Card class="h-fit">
      <CardHeader>
        <CardTitle class="flex items-center gap-2">
          <Icon name="lucide:message-circle" class="size-5 text-primary" />
           Métodos de contacto
        </CardTitle>
      </CardHeader>

      <CardContent class="space-y-4">
        {SUPPORT_CONTACT_METHODS.map(({ contact, description, icon, method }) => (
          <div class="flex items-center gap-4 p-4 bg-muted/30 rounded-lg">
            <div class="size-10 bg-primary/10 rounded-full flex items-center justify-center">
              <Icon name={icon} class="size-5 text-primary" />
            </div>
            <div>
              <div class="font-medium">{method}</div>
              <div class="text-primary">{contact}</div>
              <div class="text-sm text-muted-foreground">{description}</div>
            </div>
          </div>
        ))}
      </CardContent>
    </Card>

    <Card>
      <CardHeader>
        <CardTitle class="flex items-center gap-2">
          <Icon name="lucide:help-circle" class="size-5 text-primary" />
           Preguntas Frecuentes
        </CardTitle>
      </CardHeader>
      <CardContent class="space-y-3">
        {SUPPORT_FREQUENTLY_ASKED_QUESTIONS.map(({ answer, question }) => (
          <details class="group">
            <summary class="flex cursor-pointer items-center justify-between p-3 bg-muted/30 rounded-lg">
              <span class="font-medium">{question}</span>
              <span class="transition-transform duration-300 group-open:rotate-180">▼</span>
            </summary>

            <div class="mt-3 p-3 text-sm text-muted-foreground">{answer}</div>
          </details>
        ))}
      </CardContent>
    </Card>
  </section>

