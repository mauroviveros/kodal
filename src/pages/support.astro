  <HeadphonesIcon className="w-16 h-16 text-primary mx-auto mb-4" />
  <h1 className="text-3xl font-bold text-foreground mb-2">Centro de Soporte</h1>
  <p className="text-muted-foreground">Estamos aquí para ayudarte con tu medalla inteligente PetTag</p>
</div> -->
</Layout>
